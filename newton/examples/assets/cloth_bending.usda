#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "World"
{
    def Material "ClothMat" (
        prepend apiSchemas = ["PhysicsSurfaceDeformableMaterialAPI"]
    )
    {
        custom float physics:bendStiffness = 10
        custom float physics:density = 0.02
        custom float physics:shearStiffness = 50
        custom float physics:stretchStiffness = 50
    }

    def Mesh "Cloth" (
        prepend apiSchemas = ["PhysicsSurfaceDeformableSimAPI", "MaterialBindingAPI", "PhysicsCollisionAPI"]
    )
    {
